    {
      "parameters": {
        "jsCode": "// n8n Code 节点，语言选 JavaScript\n\nfunction cleanMarkdown(markdown) {\n  if (typeof markdown !== 'string') return '';\n\n  let result = markdown;\n\n  // 1. 图片：![alt](url)\n  result = result.replace(/!\\[[^\\]]*?\\]\\([^)]*?\\)/g, '');\n\n  // 2. 普通链接：保留文字 [text](url) -> text\n  result = result.replace(/\\[([^\\]]*?)\\]\\([^)]*?\\)/g, '$1');\n\n  // 3. 自动 / 裸链接：<https://xx> 或 https://xx 直接去掉\n  result = result.replace(/<https?:\\/\\/[^>]+>/gi, '');\n  result = result.replace(/https?:\\/\\/\\S+/gi, '');\n\n  // 4. 清理多余空格和空行\n  result = result\n    .replace(/[ \\t]+\\n/g, '\\n')   // 行尾空格\n    .replace(/\\n{3,}/g, '\\n\\n');  // 多个空行压成两个\n\n  return result.trim();\n}\n\n// 处理所有输入 items\nconst items = $input.all().map(item => {\n  const md = item.json.data || '';     // 你的 markdown 文本字段，如果是 data.content 就改成 item.json.data.content\n  const cleaned = cleanMarkdown(md);\n\n  // 你可以覆盖原字段，也可以写到新字段：\n  item.json.cleanedData = cleaned;     // 新字段\n  // item.json.data = cleaned;         // 若想直接覆盖原来的 data，用这一行替换上面一行\n\n  return item;\n});\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
